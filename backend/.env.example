# =====================================================
# Blood War to the End - Environment Configuration
# =====================================================

# Server
PORT=3000
NODE_ENV=production
API_BASE_URL=https://api.bloodwar.io

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=bloodwar
DB_PASSWORD=your_secure_password_here
DB_NAME=bloodwar_db

# BSC Network
BSC_RPC_URL=https://bsc-dataseed1.binance.org:443
BSC_WEBSOCKET_URL=wss://bsc-ws-node.nariox.org:443
BSC_CHAIN_ID=56

# BSC Testnet (for development)
# BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# BSC_CHAIN_ID=97

# Contract Addresses (update after deployment)
FACTORY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DAWN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
BET_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Platform Wallet
PLATFORM_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# CORS
ALLOWED_ORIGINS=https://bloodwar.io,https://www.bloodwar.io

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket
WS_PORT=3001

# Sync Settings
SYNC_INTERVAL_MS=5000
SYNC_START_BLOCK=0
